datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  name             String
  role             String            @default("EMPLOYEE") // ADMIN, MANAGER, EMPLOYEE
  departmentId     String?
  department       Department?       @relation(fields: [departmentId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  assets           Asset[]           @relation("UserAssets")
  bookings         Booking[]
  maintenanceReqs  Maintenance[]     @relation("Reporter")
  transfersSent    TransferRequest[] @relation("Sender")
  transfersRecv    TransferRequest[] @relation("Receiver")
  logs             ActivityLog[]
  notifications    Notification[]
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  assets    Asset[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   @default("ASSET") // ASSET or RESOURCE
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]
}

model Asset {
  id             String            @id @default(uuid())
  name           String
  tag            String            @unique // Unique Barcode/QR Tag e.g. AST-0001
  categoryId     String
  category       Category          @relation(fields: [categoryId], references: [id])
  status         String            @default("AVAILABLE") // AVAILABLE, ALLOCATED, MAINTENANCE, RETIRED
  location       String
  serialNumber   String?
  purchaseDate   DateTime          @default(now())
  cost           Float
  departmentId   String?
  department     Department?       @relation(fields: [departmentId], references: [id])
  currentUserId  String?
  currentUser    User?             @relation("UserAssets", fields: [currentUserId], references: [id])
  imageUrl       String?
  qrCode         String?           // Data URL or generated code
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  bookings       Booking[]
  maintenance    Maintenance[]
  transfers      TransferRequest[]
}

model Booking {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime
  purpose   String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Maintenance {
  id            String    @id @default(uuid())
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id])
  reporterId    String
  reporter      User      @relation("Reporter", fields: [reporterId], references: [id])
  description   String
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status        String    @default("PENDING") // PENDING, APPROVED, IN_PROGRESS, RESOLVED
  cost          Float     @default(0.0)
  scheduledDate DateTime?
  completedDate DateTime?
  comments      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model TransferRequest {
  id                 String      @id @default(uuid())
  assetId            String
  asset              Asset       @relation(fields: [assetId], references: [id])
  senderId           String
  sender             User        @relation("Sender", fields: [senderId], references: [id])
  receiverId         String
  receiver           User        @relation("Receiver", fields: [receiverId], references: [id])
  targetDepartmentId String?
  status             String      @default("PENDING") // PENDING, APPROVED, REJECTED
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, WARNING, SUCCESS
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String
  ipAddress String?
  createdAt DateTime @default(now())
}
